/* pages/play/play.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.game-header {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  width: 100%;
  max-width: 700rpx;
  box-sizing: border-box;
}

.score-time {
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
}

.score, .time {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.controls {
  display: flex;
  justify-content: center;
  gap: 20rpx;
}

.control-btn {
  background: #667eea;
  color: white;
  border: none;
  border-radius: 30rpx;
  padding: 16rpx 40rpx;
  font-size: 28rpx;
  line-height: 1;
}

.game-board {
  display: flex;
  justify-content: center;
  align-items: center;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.game-board canvas {
  background: #FFF5F5;
  border-radius: 10rpx;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.1);
}

.footer {
  margin-top: 20rpx;
  display: flex;
  justify-content: center;
}

.back-btn {
  background: rgba(255, 255, 255, 0.9);
  color: #667eea;
  border: none;
  border-radius: 40rpx;
  padding: 24rpx 80rpx;
  font-size: 32rpx;
  font-weight: bold;
  line-height: 1;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  width: 80%;
  max-width: 600rpx;
  text-align: center;
}

.modal-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
}

.modal-name {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.modal-actor {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.modal-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 30rpx;
}

.modal-close {
  background: #667eea;
  color: white;
  border: none;
  border-radius: 30rpx;
  padding: 20rpx 60rpx;
  font-size: 30rpx;
  line-height: 1;
}

.pause-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.pause-text {
  color: white;
  font-size: 60rpx;
  font-weight: bold;
  margin-bottom: 40rpx;
}

.resume-btn {
  background: #667eea;
  color: white;
  border: none;
  border-radius: 40rpx;
  padding: 30rpx 80rpx;
  font-size: 36rpx;
  line-height: 1;
}