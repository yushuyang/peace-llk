<view class="container">
  <view class="result-card">
    <text class="result-title">{{resultTitle}}</text>
    <text class="result-level">第{{level}}关 · {{levelName}}</text>

    <view class="stars-row" wx:if="{{isWin}}">
      <text class="result-star {{star1 ? 'active' : ''}}">★</text>
      <text class="result-star {{star2 ? 'active' : ''}}">★</text>
      <text class="result-star {{star3 ? 'active' : ''}}">★</text>
    </view>

    <text class="result-score">最终得分: {{score}}</text>
    <text class="result-time">用时: {{formattedTime}}</text>
    <view class="new-record" wx:if="{{isNewRecord}}"><text>🏆 新纪录！</text></view>

    <button class="btn" wx:if="{{hasNextLevel}}" bindtap="nextLevel">下一关</button>
    <button class="btn {{hasNextLevel ? 'btn-secondary' : ''}}" bindtap="playAgain">再来一次</button>
    <button class="btn btn-secondary" bindtap="backToMenu">返回菜单</button>
  </view>
</view>