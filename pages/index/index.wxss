/**index.wxss**/
.container { min-height: 100vh; display: flex; flex-direction: column; align-items: center; padding: 30rpx 24rpx 24rpx; box-sizing: border-box; }
.header { text-align: center; margin-bottom: 20rpx; }
.title { font-size: 52rpx; font-weight: bold; color: white; text-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3); display: block; margin-bottom: 8rpx; }
.subtitle { font-size: 26rpx; color: rgba(255, 255, 255, 0.85); }

/* 章节横向滚动条 */
.chapter-scroll { width: 100%; max-width: 700rpx; white-space: nowrap; margin-bottom: 16rpx; }
.chapter-list { display: inline-flex; gap: 12rpx; padding: 4rpx 0; }
.chapter-tab { display: inline-flex; flex-direction: column; align-items: center; padding: 12rpx 20rpx; border-radius: 16rpx; background: rgba(255,255,255,0.25); min-width: 100rpx; }
.chapter-tab.active { background: rgba(255,255,255,0.95); }
.chapter-tab.completed { border: 2rpx solid #FFD700; }
.ch-title { font-size: 22rpx; color: rgba(255,255,255,0.9); font-weight: bold; }
.chapter-tab.active .ch-title { color: #667eea; }
.ch-stars { font-size: 18rpx; color: rgba(255,255,255,0.7); margin-top: 2rpx; }
.chapter-tab.active .ch-stars { color: #999; }

/* 章节标题 + 翻页 */
.chapter-header { display: flex; align-items: center; justify-content: center; gap: 24rpx; margin-bottom: 16rpx; width: 100%; max-width: 700rpx; }
.ch-arrow { font-size: 36rpx; color: white; padding: 10rpx 16rpx; border-radius: 50%; background: rgba(255,255,255,0.2); }
.ch-arrow.disabled { opacity: 0.3; }
.ch-info { text-align: center; }
.ch-main-title { font-size: 36rpx; font-weight: bold; color: white; display: block; }
.ch-sub-title { font-size: 24rpx; color: rgba(255,255,255,0.8); }

/* 关卡网格 */
.level-grid { display: flex; flex-wrap: wrap; justify-content: space-between; width: 100%; max-width: 700rpx; padding: 20rpx; background: rgba(255,255,255,0.95); border-radius: 24rpx; box-sizing: border-box; box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.12); margin-bottom: 20rpx; }
.level-item { width: 30%; aspect-ratio: 1; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 18rpx; margin-bottom: 16rpx; display: flex; justify-content: center; align-items: center; position: relative; overflow: hidden; box-shadow: 0 4rpx 14rpx rgba(102,126,234,0.3); }
.level-item:nth-child(3n+2) { margin-left: 5%; margin-right: 5%; width: 30%; }
.level-item.locked { background: #bbb; box-shadow: none; }
.level-lock { display: flex; flex-direction: column; justify-content: center; align-items: center; }
.lock-icon { font-size: 40rpx; }
.lock-num { font-size: 22rpx; color: rgba(255,255,255,0.7); margin-top: 4rpx; }
.level-content { display: flex; flex-direction: column; align-items: center; justify-content: center; width: 100%; height: 100%; padding: 8rpx; box-sizing: border-box; }
.level-num { font-size: 44rpx; font-weight: bold; color: white; line-height: 1.1; }
.level-name { font-size: 20rpx; color: rgba(255,255,255,0.85); margin-top: 2rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 100%; }
.level-stars { display: flex; gap: 4rpx; margin-top: 4rpx; }
.star { font-size: 22rpx; color: rgba(255,255,255,0.4); }
.star.active { color: #FFD700; }
.level-size { font-size: 18rpx; color: rgba(255,255,255,0.65); margin-top: 2rpx; }

/* 底部按钮 */
.bottom-btns { width: 100%; max-width: 700rpx; display: flex; gap: 20rpx; }
.bottom-btns .btn { flex: 1; font-size: 28rpx; padding: 22rpx 0; }