/**index.wxss**/
.container { min-height: 100vh; display: flex; flex-direction: column; align-items: center; padding: 60rpx 40rpx; }
.header { text-align: center; margin-bottom: 60rpx; }
.title { font-size: 56rpx; font-weight: bold; color: white; text-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3); display: block; margin-bottom: 20rpx; }
.subtitle { font-size: 28rpx; color: rgba(255, 255, 255, 0.8); }
.menu-card { background: white; border-radius: 30rpx; padding: 50rpx 40rpx; width: 100%; max-width: 600rpx; box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2); }
.best-score { text-align: center; margin-bottom: 40rpx; padding: 20rpx; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 20rpx; }
.best-score .label { display: block; font-size: 24rpx; color: rgba(255, 255, 255, 0.8); margin-bottom: 10rpx; }
.best-score .value { font-size: 48rpx; font-weight: bold; color: white; }
.start-btn { width: 100%; margin-bottom: 30rpx; }
.difficulty-selector { margin-bottom: 30rpx; }
.difficulty-selector .label { display: block; font-size: 28rpx; color: #333; margin-bottom: 20rpx; text-align: center; }
.difficulty-options { display: flex; justify-content: space-around; }
.option { padding: 20rpx 40rpx; border-radius: 30rpx; background: #f5f5f5; color: #666; font-size: 28rpx; }
.option.active { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; }
.help-btn { width: 100%; background: #f5f5f5 !important; color: #666 !important; margin-bottom: 20rpx; }
.characters-btn { width: 100%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important; color: white !important; }