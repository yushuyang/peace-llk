<view class="container">
  <view class="header">
    <text class="title">《太平年》角色图鉴</text>
    <text class="subtitle">点击角色查看详细信息</text>
  </view>
  
  <scroll-view class="characters-list" scroll-y>
    <view class="character-item" wx:for="{{characters}}" wx:key="id" bindtap="showCharacterDetail" data-index="{{index}}">
      <image class="character-image" src="{{item.image}}" mode="aspectFill" lazy-load></image>
      <view class="character-info">
        <text class="name">{{item.name}}</text>
        <text class="title">{{item.title}}</text>
        <text class="actor">{{item.actor}}</text>
      </view>
    </view>
  </scroll-view>
  
  <button class="btn back-btn" bindtap="backToMenu">返回首页</button>
  
  <!-- 角色详情弹窗 -->
  <view wx:if="{{showDetail}}" class="detail-mask" bindtap="hideDetail">
    <view class="detail-card" catchtap="preventHide">
      <image class="detail-image" src="{{detailImage}}" mode="aspectFit"></image>
      <text class="name">{{detailName}}</text>
      <text class="title">{{detailTitle}}</text>
      <text class="actor">饰演: {{detailActor}}</text>
      <text class="desc">{{detailDesc}}</text>
      <button class="btn" bindtap="hideDetail">关闭</button>
    </view>
  </view>
</view>